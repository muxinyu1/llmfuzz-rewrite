# Registry
REGISTRY_IMAGE_PREFIX=crpi-8tnv6lve87c20oxm.cn-beijing.personal.cr.aliyuncs.com/llmfuzz/llmfuzz-dockerhub
TORRENTPIER_IMAGE_TAG=torrentpier-php84
MARIADB_IMAGE_TAG=mariadb-10.11-revping

# Exposed ports
TORRENTPIER_HTTP_PORT=3200
TORRENTPIER_HTTPS_PORT=3443

# TorrentPier app env (from source .env.docker)
TP_HOST=localhost
TP_PORT=80
APP_ENV=production
APP_CRON_ENABLED=false
APP_DEBUG_MODE=false
APP_DEMO_MODE=false

# Database
DB_HOST=database
DB_PORT=3306
DB_DATABASE=torrentpier
DB_USERNAME=torrentpier_user
DB_PASSWORD=secret
DB_ROOT_PASSWORD=topsecret

# Default web login (will be enforced by start.sh)
WEB_DEFAULT_USER=admin
WEB_DEFAULT_PASSWORD=123456789

# Verifier callback endpoint (passed to DB container env)
VERIFIER_HOST=host.docker.internal
VERIFIER_PORT=8000
